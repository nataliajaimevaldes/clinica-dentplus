<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow">
        <div class="card-body">
          <h2 class="card-title text-center mb-4">Crear Cuenta</h2>
          
          {{#if success}}
            <div class="alert alert-success" role="alert">
              {{success}}
            </div>
          {{/if}}

          {{#if errors.general}}
            <div class="alert alert-danger" role="alert">
              {{errors.general}}
            </div>
          {{/if}}

          <form method="POST" action="/auth/register" novalidate>
            <div class="mb-3">
              <label for="email" class="form-label">Email <span class="text-danger">*</span></label>
              <input
                type="email"
                class="form-control {{#if errors.email}}is-invalid{{/if}}"
                id="email"
                name="email"
                value="{{email}}"
                placeholder="tu@email.com"
                required>
              {{#if errors.email}}
                <div class="invalid-feedback d-block">
                  {{errors.email}}
                </div>
              {{/if}}
            </div>

            <div class="mb-3">
              <label for="password" class="form-label">Contraseña <span class="text-danger">*</span></label>
              <input
                type="password"
                class="form-control {{#if errors.password}}is-invalid{{/if}}"
                id="password"
                name="password"
                placeholder="Mínimo 6 caracteres"
                required>
              {{#if errors.password}}
                <div class="invalid-feedback d-block">
                  {{errors.password}}
                </div>
              {{/if}}
              <small class="form-text text-muted">Mínimo 6 caracteres</small>
            </div>

            <div class="mb-3">
              <label for="passwordConfirm" class="form-label">Confirmar Contraseña <span class="text-danger">*</span></label>
              <input
                type="password"
                class="form-control {{#if errors.passwordConfirm}}is-invalid{{/if}}"
                id="passwordConfirm"
                name="passwordConfirm"
                placeholder="Repite tu contraseña"
                required>
              {{#if errors.passwordConfirm}}
                <div class="invalid-feedback d-block">
                  {{errors.passwordConfirm}}
                </div>
              {{/if}}
            </div>

            <button type="submit" class="btn btn-success w-100">Crear Cuenta</button>
          </form>

          <hr>

          <p class="text-center">
            ¿Ya tienes cuenta? 
            <a href="/auth/login">Inicia sesión</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
