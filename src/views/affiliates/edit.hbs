<h1>Editar Afiliado</h1>
<form action="/affiliates/update/{{affiliate.id}}" method="POST">

  <div>
    <label for="firstName">
      Nombre
    </label>

    <input
      type="text"
      id="firstName"
      name="firstName"
      value="{{affiliate.firstName}}"
      required
    >
  </div>

  <br>

  <div>
    <label for="lastName">
      Apellido
    </label>

    <input
      type="text"
      id="lastName"
      name="lastName"
      value="{{affiliate.lastName}}"
      required
    >
  </div>

  <br>

  <div>
    <label for="email">
      Email
    </label>

    <input
      type="email"
      id="email"
      name="email"
      value="{{affiliate.email}}"
      required
    >
  </div>

  <br>

  <div>
    <label for="membershipType">
      Tipo de afiliación
    </label>

    <select
      id="membershipType"
      name="membershipType"
      required
    >

      <option
        value="silver"
        {{#ifEquals affiliate.membershipType "silver"}}
          selected
        {{/ifEquals}}
      >
        Silver
      </option>

      <option
        value="gold"
        {{#ifEquals affiliate.membershipType "gold"}}
          selected
        {{/ifEquals}}
      >
        Gold
      </option>

      <option
        value="platinum"
        {{#ifEquals affiliate.membershipType "platinum"}}
          selected
        {{/ifEquals}}
      >
        Platinum
      </option>

    </select>
  </div>

  <br>

  <button type="submit">
    Guardar cambios
  </button>

</form>

<br>

<a href="/affiliates">
  ← Volver al listado
</a>